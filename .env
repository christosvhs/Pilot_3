# Directory containing the fine-tuned LaBSE checkpoint (must contain best.pt).
CHECKPOINT_DIR=/absolute/path/to/checkpoint_dir

# Directory containing the ChromaDB persistent store (sqlite + parquet files).
CHROMA_DB_PATH=/absolute/path/to/chroma_db

# HuggingFace cache directory on the host. Models (~30 GB) are downloaded here
# on first run and reused across container restarts.
HF_CACHE_DIR=/home/youruser/.cache/huggingface
