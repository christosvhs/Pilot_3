# Directory containing the ChromaDB persistent store (sqlite + parquet files).
CHROMA_DB_PATH=/absolute/path/to/chroma_db

# HuggingFace cache directory on the host. The fine-tuned retriever and the LLMs
# (~30 GB total) are downloaded here on first run and reused across restarts.
HF_CACHE_DIR=/home/youruser/.cache/huggingface

# Optional: override the fine-tuned retriever model on HuggingFace.
# FINETUNED_MODEL_ID=Cutting3dg3/LaBSE-TID
